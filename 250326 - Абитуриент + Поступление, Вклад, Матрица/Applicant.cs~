namespace Project;
using System;
using System.Globalization;

public class Applicant {
    private string _name;
    private string _lastname;
    private string _surname;
    private double _averageGrade;
    private double _personalAchievement;
    private string _date;

    public Applicant(string name, string lastname, string surname, double averageGrade, double personalAchievement, string date) {
        _name = name;
        _lastname = lastname;
        _surname = surname;
        _averageGrade = averageGrade;
        _personalAchievement = personalAchievement;
        _date = date;
    }
    public static bool operator <(Applicant first, Applicant second) {
        if (first._averageGrade != second._averageGrade)
            return first._averageGrade < second._averageGrade;
        return first._personalAchievement < second._personalAchievement;
    }
    public static bool operator >(Applicant first, Applicant second) {
        if (first._averageGrade != second._averageGrade)
            return first._averageGrade > second._averageGrade;
        return first._personalAchievement > second._personalAchievement;
    }
    public double AverageGrade {
	get {return _averageGrade;}
	set {_averageGrade = value'}
    }
    public static void Run() {
        Applicant applicant = null;
        Applicant applicant2 = null;

        uint fullData = 0;

        while (fullData < 2) {
            Console.Write($"Введите имя {fullData + 1} студента: ");
            string name = Console.ReadLine();
            Console.Write($"Введите фамилию {fullData + 1} студента: ");
            string lastname = Console.ReadLine();
            Console.Write($"Введите отчество {fullData + 1} студента: ");
            string surname = Console.ReadLine();
            Console.Write($"Введите средний балл аттестата {fullData + 1} студента: ");
            double averageGrade = double.Parse(Console.ReadLine(), CultureInfo.InvariantCulture);
            Console.Write($"Введите балл за личные достижения {fullData + 1} студента: ");
            double personalAchievement = double.Parse(Console.ReadLine(), CultureInfo.InvariantCulture);
            Console.Write($"Введите дату подачи документов для {fullData + 1} студента: ");
            string date = Console.ReadLine();

            if (fullData == 0)
                applicant = new Applicant(name, lastname, surname, averageGrade, personalAchievement, date);
            else
                applicant2 = new Applicant(name, lastname, surname, averageGrade, personalAchievement, date);

            fullData++;
        }

        Applicant[] applicants = new Applicant[2] { applicant, applicant2 };

        foreach (var get in applicants) {
            Console.WriteLine($"Имя: {get._name} | Фамилия: {get._lastname} | Отчество: {get._surname} | Средний балл аттестата: {get._averageGrade} | Балл за личные достижения: {get._personalAchievement} | Дата подачи документов: {get._date}");
        }
	
        if (applicant > applicant2) {
            Console.WriteLine("Первый абитуриент имеет преимущество (выше средний балл или личные достижения)");
        }
        else if (applicant < applicant2) {
            Console.WriteLine("Второй абитуриент имеет преимущество (выше средний балл или личные достижения)");
        }
        else {
            Console.WriteLine("Абитуриенты равны по среднему баллу и личным достижениям");
        }
	
        Console.Write("1) 1 абитуриент\n2) 2 абитуриент\nВыберите абитуриента для проверки на соответствие с проходным баллом: ");
        int selectApplicant = int.Parse(Console.ReadLine());

        if (selectApplicant == 1) {
            if (Admission.IsPassingScore(applicant))
                Console.WriteLine("Средний балл абитуриента соответствует проходному баллу");
            else
                Console.WriteLine("Средний балл абитуриента НЕ соответствует проходному баллу");
        }
        else if (selectApplicant == 2) {
            if (Admission.IsPassingScore(applicant2))
                Console.WriteLine("Средний балл абитуриента соответствует проходному баллу");
            else
                Console.WriteLine("Средний балл абитуриента не соответствует проходному баллу");
        }
        else {
            Console.WriteLine("Такой абитуриент не найден");
        }
    }
}
