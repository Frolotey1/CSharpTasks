namespace Project;

using System;

public static class FourthTaskClass {
    public static void FourthTask() {
	Console.WriteLine("Нажмите на клавишу для запуска четвертого задания");
        Console.ReadKey();

        int M = 0, N = 0;
	while(true) {
	    Console.Write("Напишите число M: ");
	    M = int.Parse(Console.ReadLine());
	    Console.Write("Напишите число N: ");
	    N = int.Parse(Console.ReadLine());

	    if(M < 0 || N < 0) {
		Console.WriteLine("Размер столбцов и колонок не может быть отрицательным");
	    } else {
		int[,] array = new int[M,N];

		Random randomGenerate = new Random();

		for(int i = 0; i < M; ++i) {
		    for(int j = 0; j < N; ++j) {
			array[i,j] = randomGenerate.Next(0,100);
		    }
		}

		int column1 = 0, column2 = 0;
		Console.Write("Напишите число для первой колонки: ");
		column1 = int.Parse(Console.ReadLine());
		Console.Write("Напишите число для второй колонки: ");
		column2 = int.Parse(Console.ReadLine());

		Console.WriteLine("Изначальный двумерный массив: ");

		for(int i = 0; i < M; ++i) {
		    for(int j = 0; j < N; ++j) {
			Console.Write($"{array[i,j]} ");
		    }
		}
		Console.WriteLine("");

		if(column1 < 0 || column2 < 0) {
		    Console.WriteLine("Колонки не могут быть отрицательными");
		} else {
		    for(int i = 0; i < M; ++i) {
			int temp = array[i,column1];
			array[i,column1] = array[i,column2];
			array[i,column2] = temp;
		    }

		    Console.WriteLine("Двумерный массив с поменявшимися столбцами: ");
		    for(int i = 0; i < M; ++i) {
			for(int j = 0; j < N; ++j) {
			    Console.Write($"{array[i,j]}");
			}			
		    }
		    Console.WriteLine("");

		    break;
		}		
	    }
	}
    }
}
