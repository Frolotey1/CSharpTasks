namespace Project;
using System;

public class Point2D<T> {
    public T X {get; set;}
    public T Y {get; set;}

    public Point2D(T x, T y) {
	X = x;
	Y = y;
    }

    public Point2D() {
	X = default(T);
	Y = default(T);
    }    
}

public class Point3D : Point2D<int> {
    public Point3D() : base() {}
    public Point3D(int x, int y) : base(x,y) {
	X = x;
	Y = y;
    }
    public override string ToString() {
	return string.Format($"X = {X} | Y = {Y}");
    }
}

public class Line<T> where T : struct, IComparable, IConvertible, IFormattable {
    private Point2D<T> point1;
    private Point3D<T> point2;

    public Line(Point2D<T> p1, Point3D<T> p2) {
        point1 = p1;
        point2 = p2;
    }

    public Line(T x1, T y1, T x2, T y2) {
        point1 = new Point2D<T>(x1, y1);
        point2 = new Point3D<T>(x2, y2);
    }

    public override string ToString() {
        return string.Format("Прямая проходит через точки: {0} и {1}", point1, point2);
    }

    public static void Run() {

        Console.WriteLine("Введите координаты первой точки:");
        Console.Write("x1 = ");
        double x1 = double.Parse(Console.ReadLine());
        Console.Write("y1 = ");
        double y1 = double.Parse(Console.ReadLine());

        Console.WriteLine("Введите координаты второй точки:");
        Console.Write("x2 = ");
        double x2 = double.Parse(Console.ReadLine());
        Console.Write("y2 = ");
        double y2 = double.Parse(Console.ReadLine());

        Line<double> line = new Line<double>(x1, y1, x2, y2);
        
        Console.WriteLine(line.ToString());

        if (Math.Abs(x1 - x2) < 0.0001) {
            Console.WriteLine($"Уравнение прямой: x = {x1}");
        }
        else {
            double k = (y2 - y1) / (x2 - x1);
            double b = y1 - k * x1;
            
            if (b >= 0)
                Console.WriteLine($"Уравнение прямой: y = {k} | x + {b}");
            else
                Console.WriteLine($"Уравнение прямой: y = {k} | x - {Math.Abs(b)}");
        }
    }
}
