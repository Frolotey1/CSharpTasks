namespace Project;
using System;
using System.Collections.Generic;

public class Translator {
    private static Dictionary<string,string> translator;
    private static string[] save;
    
    public Translator() {
        translator = new Dictionary<string,string>();
        translator["Германия"] = "Germany";
        translator["Италия"] = "Italy";
        translator["Франция"] = "France";
        translator["Швейцария"] = "Switzerland";
        translator["Швеция"] = "Sweden";
        translator["Польша"] = "Poland";
        save = new string[6];
    }
    
    public static void Run() {	
        Console.Write("1) Русско-английский словарь\n2) Англо-русский словарь\n3) Выход\nВыберите опцию: ");
        int selectOption = int.Parse(Console.ReadLine());

        switch(selectOption) {
            case 1:
                RussianEnglishTranslator();
                break;
            case 2:
                EnglishRussianTranslator();
                break;
            case 3:
                Console.WriteLine("Завершение программы");
                break;
            default:
                Console.WriteLine("Нет такой опции");
                break;
        }
    }
    
    private static void RussianEnglishTranslator() {
        int index = 0;
        foreach(var fromRussianToEnglish in translator.Keys) {
            save[index] = fromRussianToEnglish;
            index++;
            Console.WriteLine($"{index}) {fromRussianToEnglish}");
        }
        Console.Write("Выберите слово: ");
        int selectCountry = int.Parse(Console.ReadLine());

        string translation = "";

        switch(selectCountry) {
            case int check when check >= 1 && check <= 6:
                translation = translator[save[check - 1]];
                break;
            default:
                Console.WriteLine("Нет такого слова");
                break;
        }

        if(string.IsNullOrEmpty(translation)) { 
            Console.WriteLine("Не найден перевод слова");
            Array.Clear(save,0,save.Length);
        }
        else {
            Console.WriteLine($"Переведенное слово на английский: {translation}");
            Array.Clear(save,0,save.Length);
        }
    }
    
    private static void EnglishRussianTranslator() {
        int index = 0;
        string keysAndValues = "";
        foreach(var getAll in translator) {
            keysAndValues = getAll.Value + " " + getAll.Key;
            save[index] = keysAndValues;
            index++;
            Console.WriteLine($"{index}) {getAll.Value}");
        }
        Console.Write("Выберите слово: ");
        int selectCountry = int.Parse(Console.ReadLine());

        string translation = "";

        switch(selectCountry) {
            case int check when check >= 1 && check <= 6:
                string splitString = save[check - 1];
                string[] splitParts = splitString.Split(' ');
                translation = splitParts[1];
                break;
            default:
                Console.WriteLine("Не найдено слово");
                break;
        }

        if(string.IsNullOrEmpty(translation)) {  
            Console.WriteLine("Не найден перевод слова");
            Array.Clear(save,0,save.Length);
        } else {
            Console.WriteLine($"Перевод слова на русский: {translation}");
            Array.Clear(save,0,save.Length);
        }
    }
}
