namespace Project;
using System;

public class Student {
    private string name;
    private string lastName;
    private string surname;
    private string group;
    private uint age;
    private uint[][] grades;  
    private string Name {
        get { return name; }
        set { name = value; }
    }  
    private string LastName {
        get { return lastName; }
        set { lastName = value; }
    }   
    private string Surname {
        get { return surname; }
        set { surname = value; }
    } 
    private string Group {
        get { return group; }
        set { group = value; }
    }    
    private uint Age {
        get { return age; }
        set { age = value; }
    }
    public void Run() {
        Console.WriteLine("Нажмите на любую клавишу для запуска программы с студентами: ");
        Console.ReadKey();
        
        Console.Write("Напишите имя студента: ");
        Name = Console.ReadLine();
        Console.Write("Напишите фамилию студента: ");
        LastName = Console.ReadLine();
        Console.Write("Напишите отчество для студента: ");
        Surname = Console.ReadLine();
        Console.Write("Напишите возраст студента: ");
        Age = uint.Parse(Console.ReadLine());
        Console.Write("Напишите группу, в которой учится студент: ");
        Group = Console.ReadLine();
        
        grades = new uint[3][];
        grades[0] = new uint[0]; 
        grades[1] = new uint[0]; 
        grades[2] = new uint[0];
        
        Options();
    }
    
    private void Options() {
        Console.WriteLine("\n1) Поставить оценки\n2) Получить оценки\n3) Получить средний балл за предмет\n4) Показать данные студента\n5) Выход\nВыберите опцию: ");
        int selectOption = int.Parse(Console.ReadLine());
        
        switch(selectOption) {
            case 1:
                setGrades();
                break;
            case 2:
                getGrades();
                break;
            case 3:
                AverageGrade();
                break;
            case 4:
                Console.WriteLine(StudentData());
                Options();
                break;
            case 5:
                Console.WriteLine("Выход из программы");
                break;
            default:
                Console.WriteLine("Нет такой опции");
                Options();
                break;
        }
    }
    
    private void setGrades() {
        string[] courses = new string[] { "Администрирование", "Программирование", "Дизайн" };
        Console.WriteLine("\n1) Администрирование\n2) Программирование\n3) Дизайн\nВыберите курс: ");
        int selectCourse = int.Parse(Console.ReadLine());
        
        if (selectCourse >= 1 && selectCourse <= 3) {
            int courseIndex = selectCourse - 1;
            Console.Write($"Введите количество оценок, которые получил студент за курс '{courses[courseIndex]}': ");
            int countGrades = int.Parse(Console.ReadLine());
            
            uint[] newGrades = new uint[countGrades];
            for (int i = 0; i < countGrades; i++) {
                Console.Write("Введите оценку (от 1 до 5): ");
                uint grade = uint.Parse(Console.ReadLine());
                
                if (grade < 1 || grade > 5) {
                    Console.WriteLine("Ошибка ввода оценки");
                    i--; 
                } else {
                    newGrades[i] = grade;
                }
            }
            
            grades[courseIndex] = newGrades;
            
            Console.Write("Для заполнения оценок по другим предметам напишите 1, иначе любую цифру для возвращения к списку опций: ");
            int continueOrNot = int.Parse(Console.ReadLine());
            if (continueOrNot == 1) {
                setGrades();
            } else {
                Options();
            }
        } else {
            Console.WriteLine("Нет такого курса");
            Options();
        }
    }
    
    private void AverageGrade() {
        string[] courses = new string[] { "Администрирование", "Программирование", "Дизайн" };
        Console.WriteLine("\n1) Администрирование\n2) Программирование\n3) Дизайн\nВыберите курс: ");
        int selectCourse = int.Parse(Console.ReadLine());
        
        if (selectCourse >= 1 && selectCourse <= 3) {
            int courseIndex = selectCourse - 1;
            uint[] courseGrades = grades[courseIndex];
            
            if (courseGrades.Length == 0) {
                Console.WriteLine($"По предмету '{courses[courseIndex]}' нет оценок");
                Options();
                return;
            }
            
            double sum = 0.0;
            for (int i = 0; i < courseGrades.Length; i++) {
                sum += courseGrades[i];
            }
            double average = sum / courseGrades.Length;
            Console.WriteLine($"Средний балл по предмету '{courses[courseIndex]}': {average:F2}");
	    Options()
        } else {
            Console.WriteLine("Нет такого курса");
            Options();
        }
    }
    
    private void getGrades() {
        string[] courses = new string[] { "Администрирование", "Программирование", "Дизайн" };
        Console.WriteLine("\n1) Администрирование\n2) Программирование\n3) Дизайн\nВыберите курс: ");
        int selectCourse = int.Parse(Console.ReadLine());
        
        if (selectCourse >= 1 && selectCourse <= 3) {
            int courseIndex = selectCourse - 1;
            uint[] courseGrades = grades[courseIndex];
            
            if (courseGrades.Length == 0) {
                Console.WriteLine($"По предмету '{courses[courseIndex]}' нет оценок");
            } else {
                Console.Write($"Оценки по предмету '{courses[courseIndex]}': ");
                for (int i = 0; i < courseGrades.Length; i++) {
                    Console.Write($"{courseGrades[i]} ");
                }
                Console.WriteLine();
            }
            Options();
        } else {
            Console.WriteLine("Нет такого курса");
            Options();
        }
    }
    
    private string StudentData() {
        return string.Format("Имя: {0} | Фамилия: {1} | Отчество: {2} | Возраст: {3} | Группа: {4}", 
                             Name, LastName, Surname, Age, Group);
    }
}
