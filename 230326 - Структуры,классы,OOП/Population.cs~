using System;
using AllLands.Deutschland;
using AllLands.Osterreich;
using AllLands.Schweiz;

public class Population {
    private Berlin berlin = new Berlin();
    private Wien wien = new Wien();
    private Bern bern = new Bern();    
    
    public void Run() {
        while (true) {
            Console.WriteLine("\n1) Добавить информацию\n2) Сравнить население\n3) Показать все данные\n4) Выход\nВыберите опцию: ");           
            int choice = int.Parse(Console.ReadLine());
            
            switch (choice) {
                case 1:
                    AddInfo();
                    break;
                case 2:
                    Compare();
                    break;
                case 3:
                    ShowAll();
                    break;
                case 4:
                    Console.WriteLine("Завершение программы");
                    return;
            }
        }
    }
    
    private static void AddInfo(uint attempt = 1) {
        if (attempt > 3) {
            Console.WriteLine("Было использовано более 3 попыток ввода данных странам мира");
            return;
        }
        
        Console.WriteLine("\n1) Германия\n2) Австрия\n3) Швейцария\n4) Выход в меню");
        Console.Write("Выберите страну: ");
        int country = int.Parse(Console.ReadLine());
        
        int continueOrNot = 1;
        
        if (country == 1) {
            Console.Write("Канцлер Германии: ");
            berlin.BundesKanzler = Console.ReadLine();
            Console.Write("Население Берлина: ");
            berlin.Population = uint.Parse(Console.ReadLine());
            
            Console.Write("Для заполнения данных других стран напишите 1, иначе любую цифру для возвращения к меню: ");
            continueOrNot = int.Parse(Console.ReadLine());
            
            if (continueOrNot == 1) {
                AddInfo(attempt + 1);
            } else Run();
        }
        else if (country == 2) {
            Console.Write("Канцлер Австрии: ");
            wien.BundesKanzler = Console.ReadLine();
            Console.Write("Население Вены: ");
            wien.Population = uint.Parse(Console.ReadLine());
            
            Console.Write("Для заполнения данных других стран напишите 1, иначе любую цифру для возвращения к меню: ");
            continueOrNot = int.Parse(Console.ReadLine());
            
            if (continueOrNot == 1) {
                AddInfo(attempt + 1);
            } else Run();
        }
        else if (country == 3) {
            Console.Write("Канцлер Швейцарии: ");
            bern.BundesKanzler = Console.ReadLine();
            Console.Write("Население Берна: ");
            bern.Population = uint.Parse(Console.ReadLine());
            
            Console.Write("Для заполнения данных других стран напишите 1, иначе любую цифру для возвращения к меню: ");
            continueOrNot = int.Parse(Console.ReadLine());
            
            if (continueOrNot == 1) {
                AddInfo(attempt + 1);
            } else Run();
        }
        else if (country == 4) {
            Run();
        }
        else {
            Console.WriteLine("Неверный выбор");
	    Run();
        }
    }
    
    private static void Compare() {
        Console.WriteLine($"\nНаселение Берлина: {berlin.Population}");
        Console.WriteLine($"Население Вены: {wien.Population}");
        Console.WriteLine($"Население Берна: {bern.Population}");
        
        if (berlin.Population > wien.Population && berlin.Population > bern.Population)
            Console.WriteLine("Берлин - самый населенный");
        else if (wien.Population > berlin.Population && wien.Population > bern.Population)
            Console.WriteLine("Вена - самая населенная");
        else if (bern.Population > berlin.Population && bern.Population > wien.Population)
            Console.WriteLine("Берн - самый населенный");
        else if (berlin.Population == wien.Population && berlin.Population == bern.Population && berlin.Population > 0)
            Console.WriteLine("Население всех столиц одинаковое");
        else
            Console.WriteLine("Население одинаковое или данные не заполнены");
    }
    
    private static void ShowAll() {
        Console.WriteLine($"\nГермания: канцлер {berlin.BundesKanzler}, население {berlin.Population}");
        Console.WriteLine($"Австрия: канцлер {wien.BundesKanzler}, население {wien.Population}");
        Console.WriteLine($"Швейцария: канцлер {bern.BundesKanzler}, население {bern.Population}");
    }
}
