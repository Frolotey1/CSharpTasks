namespace Project;

using System;
using System.Collections.Generic;
using System.Linq;

public class SecondTaskClass 
{
    public static void SecondTask() 
    {
        Console.WriteLine("Нажмите на клавишу для запуска второго задания: ");
        Console.ReadKey();

        Dictionary<int, string> listEvents = new Dictionary<int, string>();
        listEvents[1] = "Пришло";
        listEvents[2] = "Реализовано";
        listEvents[3] = "Списано";
        listEvents[4] = "Передано";
        
        List<string> productTypes = new List<string>();

        string getEvent = "", setName = "", setManufacturer = "", setType = ""; 
        uint setCreationYear = 0;

        while(true) 
        {
            Console.Write("\n1) Доставить\n2) Реализовать\n3) Списать\n4) Передать\n5) Выход\nВыберите опцию: ");
            int select = int.Parse(Console.ReadLine());
            
            getEvent = ""; 

            switch(select) 
            {
                case int getSelected when getSelected >= 1 && getSelected <= 4:
                    getEvent = listEvents[getSelected];
                    break;
                case 5:
                    Console.WriteLine("Завершение программы");
                    return;
                default:
                    Console.WriteLine("Нет такой опции");
                    break;
            }

            if(getEvent.Equals(""))
            {
                Console.WriteLine("Невозможно проводить операции с товаром без события");
            }
            else 
            {
                Console.Write("Напишите название товара: ");
                setName = Console.ReadLine();
                Console.Write("Напишите производителя товара: ");
                setManufacturer = Console.ReadLine();
                Console.Write("Напишите год создания товара: ");
                setCreationYear = uint.Parse(Console.ReadLine());
                Console.Write("Напишите тип товара: ");
                setType = Console.ReadLine();
                
                if (!productTypes.Contains(setType))
                    productTypes.Add(setType);

                Product product = new Product(setName, setManufacturer, setCreationYear, setType, getEvent);
                string currentEvent = ""; 

                Console.Write("Для добавления еще товара напишите 1. Напишите 0 для работы с текущим товаром: ");
                int continueOrNot = int.Parse(Console.ReadLine());

                if(continueOrNot == 0) 
                {
                    Console.Write("1) Пришло\n2) Реализовано\n3) Списано\n4) Передано\nВыберите опцию: ");
                    int selectOption = int.Parse(Console.ReadLine());

                    if (listEvents.ContainsKey(selectOption))
                        currentEvent = listEvents[selectOption];

                    if(currentEvent.Equals("")) 
                    {
                        Console.WriteLine("Невозможно вывести информацию о товаре без опции");
                    }
                    else 
                    {
                        for(int i = 0; i < productTypes.Count; ++i) 
                        {
                            Console.WriteLine($"{i + 1}) {productTypes[i]}");
                        }

                        Console.Write("Выберите тип товара: ");
                        int selectType = int.Parse(Console.ReadLine());

                        if(selectType >= 1 && selectType <= productTypes.Count) 
                            product.show(currentEvent, productTypes[selectType - 1]);
                        else
                            Console.WriteLine("Такой тип товара не существует");
                    }
                }
            }
        }
    }
    
    public class Product 
    {
        public string Name { get; set; }
        public string Manufacturer { get; set; }
        public uint CreationYear { get; set; }
        public string Type { get; set; }
        public string EventField { get; set; }
        
        private List<Product> products = new List<Product>();
        
        public Product(string name, string manufacturer, uint creationYear, string type, string eventField) 
        {
            Name = name;
            Manufacturer = manufacturer;
            CreationYear = creationYear;
            Type = type;
            EventField = eventField;            
            products.Add(this);
        }
        
        public void show(string getEvent, string getType) 
        {
            var result = products
                .Where(p => p.EventField.Equals(getEvent) && p.Type.Equals(getType))
                .ToList();
                
            if (result.Count == 0) Console.WriteLine("Совпадений не найдено.");

            foreach(var p in result) 
            {
                Console.WriteLine($"Название: {p.Name} | Производитель: {p.Manufacturer} | Год: {p.CreationYear} | Тип: {p.Type} | Статус: {p.EventField}");
            }
        }
    }    
}
