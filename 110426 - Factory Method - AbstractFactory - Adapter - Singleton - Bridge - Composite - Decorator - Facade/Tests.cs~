        }
        sw.Stop();
        var builderTime = sw.ElapsedMilliseconds;
        
        var original = new ClonableDialog();
        original.Title = "Шаблон";
        original.Buttons.Add(new ClonableButtonComponent("Default", new FluentRenderingStrategy(), "OK"));
        
        sw.Restart();
        for (int i = 0; i < 99; i++)
